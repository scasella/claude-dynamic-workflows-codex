node_modules/
.DS_Store
.env
.env.*
*.run.html
# Live-viewer update-channel sidecars (written next to the HTML by --watch/--gui)
*.run.data.js
*.run.gen.js

# Runtime resume journals — except the bundled demo run (kept for the viewer demo)
.workflow-journal/
!examples/demo/.workflow-journal/
!examples/demo/.workflow-journal/**

# Lifecycle event sidecars (live-viewer observability) are runtime-only, never committed
*.events.jsonl
# Persisted workflow return value + live partial-output sidecars — runtime-only.
# Listed last so they override the demo-journal un-ignore above.
*.result.json
*.progress.json
